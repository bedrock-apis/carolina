{
   "private": true,
   "license": "MIT",
   "author": "bedrock-apis",
   "workspaces": [
      "packages/*",
      "app",
      "benchmarks"
   ],
   "type": "module",
   "scripts": {
      "it": "oxfmt --write && turbo check -- --pretty && turbo run build",
      "build": "turbo run build",
      "watch": "turbo run watch",
      "dump": "pnpm --filter @carolina/tools run dump",
      "start": "pnpm --filter app run start",
      "--vitest--": "",
      "test": "vitest --run",
      "bench": "vitest bench --run",
      "--checks--": "",
      "fmt": "oxfmt --write",
      "lint": "oxlint --fix-suggestions",
      "check": "turbo check -- --pretty && oxlint && oxfmt --check",
      "check:ts": "turbo check -- --pretty",
      "check:fmt": "oxfmt --check",
      "check:lint": "oxlint"
   },
   "devDependencies": {
      "@types/bun": "^1.3.11",
      "@types/node": "^25.5.0",
      "@typescript/native-preview": "7.0.0-dev.20260325.1",
      "oxfmt": "0.42.0",
      "oxlint": "^1.57.0",
      "oxlint-tsgolint": "^0.17.4",
      "rolldown": "1.0.0-rc.12",
      "rolldown-plugin-dts": "^0.22.5",
      "turbo": "^2.8.20",
      "typescript": "6.0.2",
      "vitest": "^4.1.1"
   },
   "prettier": {
      "arrowParens": "avoid",
      "endOfLine": "lf",
      "printWidth": 120,
      "quoteProps": "consistent",
      "singleQuote": true,
      "tabWidth": 3
   },
   "packageManager": "pnpm@10.33.0"
}
