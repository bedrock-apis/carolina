{
   "private": true,
   "license": "MIT",
   "author": "bedrock-apis",
   "workspaces": [
      "packages/*",
      "app",
      "benchmarks"
   ],
   "type": "module",
   "scripts": {
      "it": "oxfmt --write && turbo check -- --pretty && turbo run build",
      "build": "turbo run build",
      "watch": "turbo run watch",
      "--vitest--": "",
      "test": "vitest --run",
      "bench": "vitest bench --run",
      "--checks--": "",
      "fmt": "oxfmt --write",
      "lint": "oxlint --fix-suggestions",
      "check": "turbo check -- --pretty && oxlint && oxfmt --check",
      "check:ts": "turbo check -- --pretty",
      "check:fmt": "oxfmt --check",
      "check:lint": "oxlint"
   },
   "devDependencies": {
      "@types/bun": "^1.3.2",
      "@types/node": "^24.10.1",
      "@typescript/native-preview": "7.0.0-dev.20260211.1",
      "oxfmt": "0.31.0",
      "oxlint": "^1.46.0",
      "rolldown": "1.0.0-rc.1",
      "rolldown-plugin-dts": "^0.21.6",
      "turbo": "^2.6.1",
      "typescript": "6.0.0-dev.20260211",
      "vitest": "^4.0.10"
   },
   "prettier": {
      "arrowParens": "avoid",
      "endOfLine": "lf",
      "printWidth": 120,
      "quoteProps": "consistent",
      "singleQuote": true,
      "tabWidth": 3
   },
   "packageManager": "pnpm@10.29.2"
}
